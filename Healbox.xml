<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

	<Button name="HealboxSpellButtonTemplate" inherits="SecureActionButtonTemplate" virtual="true">
		<Size x="28" y="28"/>
		<Layers>
			<Layer level="ARTWORK">
				<Texture name="$parentIcon" parentKey="icon" setAllPoints="true">
					<Color r="0.5" g="0.5" b="0.5" a="0.5" />
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				self:RegisterForClicks("AnyUp")
				self:RegisterForDrag("LeftButton")
			</OnLoad>
			<OnEnter>
				if Healbox and Healbox.OnSpellButtonEnter then Healbox:OnSpellButtonEnter(self) end
			</OnEnter>
			<OnLeave>
				GameTooltip:Hide()
			</OnLeave>
			<OnReceiveDrag>
				if Healbox and Healbox.OnSpellButtonReceiveDrag then Healbox:OnSpellButtonReceiveDrag(self) end
			</OnReceiveDrag>
			<OnDragStart>
				if Healbox and Healbox.OnSpellButtonDragStart then Healbox:OnSpellButtonDragStart(self) end
			</OnDragStart>
		</Scripts>
	</Button>

	<Button name="HealboxUnitButtonTemplate" inherits="SecureUnitButtonTemplate" virtual="true">
		<Size x="120" y="32"/>
		<Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
			<EdgeSize>
				<AbsValue val="8"/>
			</EdgeSize>
			<TileSize>
				<AbsValue val="8"/>
			</TileSize>
			<BackgroundInsets>
				<AbsInset left="2" right="2" top="2" bottom="2"/>
			</BackgroundInsets>
			<Color r="0" g="0" b="0" a="0.8"/>
		</Backdrop>
		<Frames>
			<StatusBar name="$parentHealthBar" parentKey="healthBar" drawLayer="BACKGROUND">
				<Size x="116" y="24"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="2" y="-2"/>
				</Anchors>
				<BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
				<BarColor r="0" g="1" b="0"/>
				<Layers>
					<Layer level="OVERLAY">
						<FontString name="$parentName" parentKey="name" inherits="GameFontHighlightSmall" justifyH="LEFT">
							<Anchors>
								<Anchor point="LEFT" x="6" y="0"/>
							</Anchors>
						</FontString>
						<FontString name="$parentHPText" parentKey="hpText" inherits="GameFontHighlightSmall" justifyH="RIGHT">
							<Anchors>
								<Anchor point="RIGHT" x="-6" y="0"/>
							</Anchors>
						</FontString>
					</Layer>
				</Layers>
			</StatusBar>
			<StatusBar name="$parentManaBar" parentKey="manaBar" drawLayer="BACKGROUND">
				<Size x="116" y="4"/>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentHealthBar" relativePoint="BOTTOMLEFT"/>
				</Anchors>
				<BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
				<BarColor r="0" g="0" b="1"/>
			</StatusBar>
		</Frames>
		<Scripts>
			<OnLoad>
				self:RegisterForClicks("AnyUp")
			</OnLoad>
			<OnShow>
				if Healbox and Healbox.OnUnitFrameShow then Healbox:OnUnitFrameShow(self) end
			</OnShow>
			<OnHide>
				if Healbox and Healbox.OnUnitFrameHide then Healbox:OnUnitFrameHide(self) end
			</OnHide>
			<OnAttributeChanged>
				if Healbox and Healbox.OnUnitFrameAttributeChanged then Healbox:OnUnitFrameAttributeChanged(self, name, value) end
			</OnAttributeChanged>
		</Scripts>
	</Button>

</Ui>
